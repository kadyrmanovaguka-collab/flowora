{
  "manifest_version": 3,
  "name": "Flowora — Website Blocker",
  "version": "1.0.0",
  "description": "Автоматически блокирует отвлекающие сайты во время фокус-сессии Flowora",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "alarms",
    "declarativeNetRequest"
  ],

  "host_permissions": [
    "https://your-flowora-domain.vercel.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://your-flowora-domain.vercel.app/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "declarative_net_request": {
    "rule_resources": []
  }
}
