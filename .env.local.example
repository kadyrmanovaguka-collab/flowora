# =============================================================================
# FLOWORA — переменные окружения
# =============================================================================
# Скопируй этот файл в .env.local и заполни реальными значениями.
# .env.local НЕ должен попадать в git (уже добавлен в .gitignore).
#
# ⚠️ Переменные без префикса NEXT_PUBLIC_ доступны ТОЛЬКО на сервере
#    (Server Components, Route Handlers, middleware). Никогда не логируй их
#    и не передавай в клиентский код — это секреты.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# Где взять:
# 1. Зайди на https://supabase.com/dashboard → создай новый проект
# 2. Project Settings → API
#
# URL проекта. Публичный, используется и на клиенте, и на сервере.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# "anon" / "public" ключ. Тоже публичный — безопасен для клиента,
# потому что все реальные ограничения доступа задаются через RLS-политики
# в базе, а не через секретность этого ключа.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "service_role" ключ. СЕКРЕТНЫЙ. Обходит ВСЕ политики RLS.
# Используется ТОЛЬКО в серверных route handler'ах, которым нужно писать
# в базу от имени системы (например webhook от Stripe, который обновляет
# статус подписки не будучи "авторизованным" пользователем Supabase Auth).
# Никогда не отправляй его в браузер и не коммить в репозиторий.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# ПРИЛОЖЕНИЕ
# -----------------------------------------------------------------------------
# Базовый публичный URL приложения. Используется для формирования
# success_url / cancel_url в Stripe Checkout и return_url в Customer Portal.
# Локально: http://localhost:3000
# На Vercel: https://твой-домен.vercel.app (или кастомный домен)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# CHROME EXTENSION (только для серверной части, с которой общается расширение)
# -----------------------------------------------------------------------------
# Секрет, которым подписываются внутренние запросы от расширения к
# /api/sessions/active, чтобы отличать легитимные запросы расширения
# от произвольных запросов из интернета. Сгенерируй случайную строку,
# например: `openssl rand -hex 32`
EXTENSION_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
